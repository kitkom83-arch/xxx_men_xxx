generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model AdminUser {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model AppSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CredentialVault {
  id               String   @id @default(cuid())
  name             String   @unique
  mode             String   @default("mock")
  encryptedPayload Json
  maskedLabel      String
  lastUpdatedAt    DateTime @default(now())
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model SearchHistory {
  id            String   @id @default(cuid())
  type          String
  query         String
  resultSummary Json
  createdAt     DateTime @default(now())
}

model PostDraft {
  id           String   @id @default(cuid())
  text         String
  dryRun       Boolean  @default(true)
  safetyStatus String
  payload      Json
  createdAt    DateTime @default(now())
}

model RateLimitSnapshot {
  id        String   @id @default(cuid())
  endpoint  String
  limit     Int?
  remaining Int?
  resetAt   DateTime?
  createdAt DateTime @default(now())
}

model UsageSnapshot {
  id        String   @id @default(cuid())
  source    String
  postsRead Int      @default(0)
  cap       Int?
  payload   Json
  createdAt DateTime @default(now())
}

model AuditEvent {
  id        String   @id @default(cuid())
  action    String
  summary   String
  metadata  Json
  createdAt DateTime @default(now())
}
