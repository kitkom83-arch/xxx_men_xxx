# X API Marketing Control Center
# ใช้ placeholder เท่านั้น อย่าใส่ secret จริงใน repo

APP_BASE_URL=http://localhost:3000
DATABASE_URL=postgresql://xmc:xmc_password@localhost:5432/xmc?schema=public
SESSION_SECRET=replace-with-long-random-session-secret
ENCRYPTION_KEY=replace-with-long-random-encryption-key

# Demo/mock mode เป็นค่าเริ่มต้นใน database setting
# X credentials ให้ใส่ผ่าน setup wizard หรือหน้า admin เท่านั้น เพื่อเข้ารหัสฝั่ง server
